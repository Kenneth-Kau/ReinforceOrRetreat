install.packages("here")
library(dplyr)
# ============================================================
# Tybee Island Flood Risk - Data Loading Preamble
# Ken Kau - UWyoming Environmental Economics and HUNTER
# ============================================================
library(terra)
library(sf)
library(dplyr)
library(readr)
library(lubridate)
library(leaflet)      # interactive maps
library(mapview)      # even quicker spatial checks - one line to map any sf object
library(fixest)
library(stargazer)
library(here)
# ============================================================
# PATHS
# ============================================================
base <- here("RawData")
path_elev     <- file.path(base, "Elevation")
path_housing  <- file.path(base, "Housing")
path_hydro    <- file.path(base, "Hydrology")
path_bound    <- file.path(base, "Polygon/2025TybeeBound")
path_parcels  <- file.path(base, "Polygon/2023savannahINTERSECT2025Tybee")
path_tidal    <- file.path(base, "Tidal")
# ============================================================
# 1. TIDAL GAUGE
# ============================================================
tidal_raw <- read_csv(
file.path(path_tidal, list.files(path_tidal, pattern = "\\.csv$")[1]),
show_col_types = FALSE
)
cat("Tidal gauge rows:", nrow(tidal_raw), "\n")
cat("Tidal columns:", paste(names(tidal_raw), collapse = ", "), "\n\n")
# ============================================================
# 2. PARCEL POLYGONS
# ============================================================
parcels <- st_read(path_parcels)
tybee_bound <- st_read(path_bound)
cat("Parcels:", nrow(parcels), "features\n")
cat("Parcel columns:", paste(names(parcels), collapse = ", "), "\n\n")
# ============================================================
# 3. LiDAR DEM TILES
# ============================================================
tif_files <- list.files(path_elev, pattern = "\\.tif$", full.names = TRUE)
cat("DEM tiles found:", length(tif_files), "\n")
cat(basename(tif_files), sep = "\n")
cat("\n")
# ============================================================
# 4. NHD FLOWLINES
# ============================================================
hydro_files <- list.files(path_hydro, pattern = "\\.shp$", full.names = TRUE)
flowlines <- st_read(hydro_files[1])
cat("Flowline features:", nrow(flowlines), "\n")
cat("Flowline columns:", paste(names(flowlines), collapse = ", "), "\n\n")
# ============================================================
# 5. HOUSING SALES CSVs
# ============================================================
csv_files <- list.files(path_housing, pattern = "\\.csv$", full.names = TRUE)
cat("Housing CSVs found:", length(csv_files), "\n")
cat(basename(csv_files), sep = "\n")
# Peek at first file to see column structure
housing_sample <- read_csv(csv_files[1], show_col_types = FALSE)
cat("\nSample housing columns:", paste(names(housing_sample), collapse = ", "), "\n")
cat("Sample housing rows:", nrow(housing_sample), "\n")
# ============================================================
# 6. PARCEL CENTROIDS + VALIDATION MAP
# ============================================================
# Load parcel polygons
parcels <- st_read(path_parcels)
# Compute centroids
parcel_centroids <- st_centroid(parcels)
cat("Centroids computed:", nrow(parcel_centroids), "\n")
# Reproject to WGS84 for leaflet/mapview (requires lat/lon)
parcel_centroids_wgs <- st_transform(parcel_centroids, crs = 4326)
parcels_wgs <- st_transform(parcels, crs = 4326)
# Validation map - polygons + centroids overlaid
mapview(parcels_wgs, layer.name = "Parcels", col.regions = "lightblue", alpha.regions = 0.4) +
mapview(parcel_centroids_wgs, layer.name = "Centroids", col.regions = "red", cex = 2)
# ============================================================
# 7. LiDAR ELEVATION EXTRACTION + VALIDATION MAPS
# ============================================================
# Mosaic all DEM tiles
dem <- mosaic(sprc(lapply(tif_files, rast)))
cat("DEM mosaic CRS:", crs(dem, describe = TRUE)$name, "\n")
# Reproject centroids to match DEM CRS
parcel_centroids_dem <- st_transform(parcel_centroids, crs(dem))
# Extract elevation at each centroid
elev_values <- extract(dem, vect(parcel_centroids_dem))
parcel_centroids$elevation <- elev_values[, 2]
cat("Elevation extraction complete\n")
cat("Elevation range:", round(min(parcel_centroids$elevation, na.rm = TRUE), 2),
"to", round(max(parcel_centroids$elevation, na.rm = TRUE), 2), "\n")
cat("NAs:", sum(is.na(parcel_centroids$elevation)), "\n")
# Reproject to WGS84 for mapping
parcel_centroids_wgs <- st_transform(parcel_centroids, crs = 4326)
# --- MAP 1: Raw DEM heatmap (aggregated for display only) ---
dem_wgs <- project(dem, "EPSG:4326")
dem_crop <- crop(dem_wgs, ext(vect(st_transform(tybee_bound, 4326))))
dem_display <- aggregate(dem_crop, fact = 5, fun = "mean")  # 5m resolution for display
pal_raster <- colorNumeric(
palette = c("darkblue", "cyan", "green", "yellow", "orange", "red"),
values(dem_display),
na.color = "transparent"
)
map1 <- leaflet() |>
addProviderTiles("CartoDB.DarkMatter") |>
addRasterImage(dem_display, colors = pal_raster, opacity = 0.8) |>
addLegend(pal = pal_raster, values = values(dem_display),
title = "Elevation (m)", position = "bottomright")
# --- MAP 2: Centroid points colored by extracted elevation ---
pal_points <- colorNumeric(
palette = c("darkblue", "cyan", "green", "yellow", "orange", "red"),
domain = parcel_centroids_wgs$elevation,
na.color = "grey"
)
map2 <- leaflet(parcel_centroids_wgs) |>
addProviderTiles("CartoDB.DarkMatter") |>
addCircleMarkers(
radius = 4,
color = ~pal_points(elevation),
stroke = FALSE,
fillOpacity = 0.9,
popup = ~paste("PIN:", PIN, "<br>Elevation:", round(elevation, 2), "m")
) |>
addLegend(pal = pal_points, values = ~elevation,
title = "Elevation (m)", position = "bottomright")
# Display both
map1
map2
# ============================================================
# 8. DISTANCE TO WATER + VALIDATION MAP
# ============================================================
# Load NHD flowlines
flowlines <- st_read(hydro_files[1])
cat("Flowlines loaded:", nrow(flowlines), "features\n")
cat("Flowlines CRS:", st_crs(flowlines)$input, "\n")
# Reproject both to a projected CRS for accurate distance calculation
# Using NAD83 / Georgia East (ftUS) to match parcel CRS
parcel_centroids_proj <- st_transform(parcel_centroids, crs = 26967)
flowlines_proj <- st_transform(flowlines, crs = 26967) |> st_zm()
# Compute distance from each centroid to nearest flowline
cat("Computing distance to nearest flowline (may take a moment)...\n")
dist_matrix <- st_distance(parcel_centroids_proj, flowlines_proj)
parcel_centroids$dist_water_ft <- apply(dist_matrix, 1, min)
cat("Distance to water complete\n")
cat("Distance range:", round(min(parcel_centroids$dist_water_ft, na.rm = TRUE)),
"to", round(max(parcel_centroids$dist_water_ft, na.rm = TRUE)), "ft\n")
# Reproject to WGS84 for mapping
parcel_centroids_wgs <- st_transform(parcel_centroids, crs = 4326)
flowlines_wgs <- st_transform(flowlines, crs = 4326) |> st_zm()
# --- MAP: Centroids colored by distance to water + flowlines overlaid ---
pal_dist <- colorNumeric(
palette = c("darkblue", "cyan", "green", "yellow", "orange", "red"),
domain = parcel_centroids_wgs$dist_water_ft,
na.color = "grey"
)
map3 <- leaflet(parcel_centroids_wgs) |>
addProviderTiles("CartoDB.DarkMatter") |>
addPolylines(data = flowlines_wgs, color = "white", weight = 1, opacity = 0.6) |>
addCircleMarkers(
radius = 4,
color = ~pal_dist(dist_water_ft),
stroke = FALSE,
fillOpacity = 0.9,
popup = ~paste("PIN:", PIN, "<br>Distance to Water:", round(dist_water_ft), "ft")
) |>
addLegend(pal = pal_dist, values = ~dist_water_ft,
title = "Distance to Water (ft)", position = "bottomright")
map3
# QUICK CHECK FOR PART 9
# Check column names across all years
for(f in csv_files){
df <- read_csv(f, show_col_types = FALSE, n_max = 0)
cat(basename(f), ":", paste(names(df), collapse=", "), "\n\n")
}
# ============================================================
# 9. HOUSING PANEL CONSTRUCTION
# ============================================================
# --- Step 1: Define column standardization function ---
standardize_housing <- function(filepath) {
snapshot_year <- as.integer(gsub(".csv", "", basename(filepath)))
snapshot_yy   <- snapshot_year %% 100  # last 2 digits of snapshot year
df <- read_csv(filepath, show_col_types = FALSE) |>
# Standardize column names to uppercase for consistent access
rename_with(toupper)
# Extract the four columns we care about, handling name variants
pin        <- df[[intersect(c("PIN"), names(df))[1]]]
sale_price <- df[[intersect(c("SALE_PRICE"), names(df))[1]]]
sale_yy    <- df[[intersect(c("SALE_YY"), names(df))[1]]]
sale_mm    <- df[[intersect(c("SALE_MM"), names(df))[1]]]
sale_dd    <- df[[intersect(c("SALE_DD"), names(df))[1]]]
out <- tibble(
PIN        = as.character(pin),
sale_price = as.numeric(sale_price),
sale_yy    = as.integer(sale_yy),
sale_mm    = as.integer(sale_mm),
sale_dd    = as.integer(sale_dd),
snapshot_year = snapshot_year
)
return(out)
}
# --- Step 2: Stack all CSVs ---
housing_list <- lapply(csv_files, standardize_housing)
housing_raw  <- bind_rows(housing_list)
cat("Raw stacked rows:", nrow(housing_raw), "\n")
# --- Step 3: Reconstruct full 4-digit sale year ---
# Rule: if sale_yy <= snapshot last 2 digits, it's 1900s, otherwise ambiguous
# Conservative approach: cap at snapshot year, assign century accordingly
housing_raw <- housing_raw |>
mutate(
sale_year = case_when(
is.na(sale_yy)                          ~ NA_integer_,
snapshot_year >= 2000 & sale_yy <= 24   ~ 2000L + sale_yy,
TRUE                                     ~ 1900L + sale_yy
)
)
# --- Step 4: Basic cleaning ---
housing_clean <- housing_raw |>
filter(
!is.na(PIN),
!is.na(sale_price),
sale_price > 0,        # drop zero/missing price transfers
!is.na(sale_year),
!is.na(sale_mm),
sale_mm >= 1 & sale_mm <= 12,
sale_year >= 1900 & sale_year <= 2023
) |>
mutate(
sale_date = make_date(sale_year, sale_mm, 1)  # day-of-month set to 1
) |>
# Keep only parcels that appear in our Tybee parcel shapefile
filter(PIN %in% parcels$PIN) |>
select(PIN, sale_price, sale_year, sale_mm, sale_dd, sale_date, snapshot_year)
cat("Clean panel rows:", nrow(housing_clean), "\n")
cat("Unique PINs with sales:", n_distinct(housing_clean$PIN), "\n")
cat("Sale year range:", min(housing_clean$sale_year), "to", max(housing_clean$sale_year), "\n")
# --- Step 5: Pull YearBuilt and Acres from 2023 file ---
file_2023 <- csv_files[grepl("2023", csv_files)]
parcel_chars <- read_csv(file_2023, show_col_types = FALSE) |>
rename_with(toupper) |>
filter(PIN %in% parcels$PIN) |>
select(PIN, YEARBUILT, ACRES) |>
rename(year_built = YEARBUILT, acres = ACRES) |>
mutate(
PIN       = as.character(PIN),
year_built = as.integer(year_built),
acres      = as.numeric(acres)
)
cat("\nParcel characteristics (from 2023):\n")
cat("YearBuilt range:", min(parcel_chars$year_built, na.rm=TRUE),
"to", max(parcel_chars$year_built, na.rm=TRUE), "\n")
cat("Acres range:", round(min(parcel_chars$acres, na.rm=TRUE), 3),
"to", round(max(parcel_chars$acres, na.rm=TRUE), 3), "\n")
# --- Step 6: Merge panel with parcel characteristics ---
panel <- housing_clean |>
left_join(parcel_chars, by = "PIN")
cat("\nFinal panel rows:", nrow(panel), "\n")
cat("Unique PINs:", n_distinct(panel$PIN), "\n")
#BUT... how many are repeat sale?
panel |>
count(PIN) |>
summarise(
single_sale  = sum(n == 1),
repeat_sales = sum(n >= 2),
three_plus   = sum(n >= 3)
)
#NOW for part 10
cat("Tidal columns:", paste(names(tidal_raw), collapse = ", "), "\n")
head(tidal_raw)
# ============================================================
# 10. TIDAL GAUGE - DETREND AND CONSTRUCT SURGE SERIES
# ============================================================
# --- Step 1: Clean tidal data ---
tidal <- tidal_raw |>
rename(
date    = Date,
highest = Highest,
msl     = `MSL (ft)`,
flag    = `Inf`
) |>
mutate(
date       = as.Date(date),
year       = year(date),
month      = month(date),
time_index = as.numeric(date)
) |>
filter(flag == 0, !is.na(highest)) |>
select(date, year, month, highest, msl, time_index)
cat("Clean tidal observations:", nrow(tidal), "\n")
cat("Date range:", as.character(min(tidal$date)), "to", as.character(max(tidal$date)), "\n")
# --- Step 2: Detrend Highest using linear time trend ---
trend_model <- lm(highest ~ time_index, data = tidal)
cat("\nTrend model summary:\n")
print(summary(trend_model))
tidal$surge_detrended <- residuals(trend_model)
cat("\nSurge detrended summary:\n")
print(summary(tidal$surge_detrended))
# --- Step 3: Visual check - raw vs detrended ---
par(mfrow = c(2, 1))
plot(tidal$date, tidal$highest,
type = "l", col = "steelblue",
xlab = "Date", ylab = "Highest (ft)",
main = "Raw Monthly Maximum Water Level - Fort Pulaski")
abline(trend_model, col = "red", lwd = 2)
plot(tidal$date, tidal$surge_detrended,
type = "l", col = "darkorange",
xlab = "Date", ylab = "Residual (ft)",
main = "Detrended Surge Residuals")
abline(h = 0, col = "black", lty = 2)
par(mfrow = c(1, 1))
# --- Step 4: Final tidal series ready for merge ---
tidal_final <- tidal |>
select(date, year, month, highest, surge_detrended)
cat("\nTidal series ready:", nrow(tidal_final), "monthly observations\n")
cat("Surge range:", round(min(tidal_final$surge_detrended), 3),
"to", round(max(tidal_final$surge_detrended), 3), "ft\n")
# ============================================================
# 11. FINAL PANEL ASSEMBLY
# ============================================================
# At this point we have:
# - panel:        PIN x sale transaction (PIN, sale_price, sale_year, sale_mm, sale_date, year_built, acres)
# - parcel_centroids: PIN x spatial characteristics (elevation, dist_water_ft)
# - tidal_final:  year x month (date, year, month, highest, surge_detrended)
# --- Step 1: Extract elevation and distance from centroids ---
parcel_spatial <- parcel_centroids |>
st_drop_geometry() |>
select(PIN, elevation, dist_water_ft) |>
mutate(PIN = as.character(PIN))
cat("Parcel spatial characteristics:", nrow(parcel_spatial), "parcels\n")
cat("Elevation NAs:", sum(is.na(parcel_spatial$elevation)), "\n")
cat("Distance NAs:", sum(is.na(parcel_spatial$dist_water_ft)), "\n")
# --- Step 2: Merge panel with parcel spatial characteristics ---
panel_spatial <- panel |>
left_join(parcel_spatial, by = "PIN")
cat("\nAfter spatial merge:", nrow(panel_spatial), "rows\n")
cat("Elevation NAs:", sum(is.na(panel_spatial$elevation)), "\n")
# --- Step 3: Merge with tidal gauge on year x month ---
panel_full <- panel_spatial |>
left_join(tidal_final, by = c("sale_year" = "year", "sale_mm" = "month"))
cat("After tidal merge:", nrow(panel_full), "rows\n")
cat("Surge NAs:", sum(is.na(panel_full$surge_detrended)), "\n")
# --- Step 4: Construct interaction terms ---
# These are the key vulnerability exposure variables in your specification:
# surge_detrended * elevation    (higher surge x lower elevation = more exposed)
# surge_detrended * dist_water   (higher surge x closer to water = more exposed)
panel_full <- panel_full |>
mutate(
log_price         = log(sale_price),
surge_x_elev      = surge_detrended * elevation,
surge_x_dist      = surge_detrended * dist_water_ft
)
# --- Step 5: Drop rows missing key variables ---
panel_est <- panel_full |>
filter(
!is.na(log_price),
!is.na(surge_detrended),
!is.na(elevation),
!is.na(dist_water_ft)
)
cat("\n=== FINAL ESTIMATION DATASET ===\n")
cat("Observations:", nrow(panel_est), "\n")
cat("Unique PINs:", n_distinct(panel_est$PIN), "\n")
cat("Year range:", min(panel_est$sale_year), "to", max(panel_est$sale_year), "\n")
cat("Log price range:", round(min(panel_est$log_price), 2),
"to", round(max(panel_est$log_price), 2), "\n")
cat("Surge detrended range:", round(min(panel_est$surge_detrended), 3),
"to", round(max(panel_est$surge_detrended), 3), "\n")
cat("Elevation range:", round(min(panel_est$elevation), 2),
"to", round(max(panel_est$elevation), 2), "m\n")
cat("Distance to water range:", round(min(panel_est$dist_water_ft)),
"to", round(max(panel_est$dist_water_ft)), "ft\n")
# --- Step 6: Save estimation dataset ---
out_dir <- file.path(base, "Output")
dir.create(out_dir, showWarnings = FALSE)
write_csv(panel_est, file.path(out_dir, "tybee_panel_estimation.csv"))
cat("\nEstimation dataset saved to:", file.path(out_dir, "tybee_panel_estimation.csv"), "\n")
# ============================================================
# 12. REGRESSION MODELS
# ============================================================
# Spec: log(price_it) = β1(surge_t x elev_i) + β2(surge_t x dist_i) + αi + αt + εit
# Clustered SEs at year level (conservative - fewer clusters)
# --- Model 1: Pooled OLS, no fixed effects ---
m1 <- feols(
log_price ~ surge_x_elev + surge_x_dist,
data    = panel_est,
cluster = ~sale_year
)
# --- Model 2: Parcel FE only ---
m2 <- feols(
log_price ~ surge_x_elev + surge_x_dist | PIN,
data    = panel_est,
cluster = ~sale_year
)
# --- Model 3: Parcel FE + Year FE (preferred spec) ---
m3 <- feols(
log_price ~ surge_x_elev + surge_x_dist | PIN + sale_year,
data    = panel_est,
cluster = ~sale_year
)
# --- Model 4: Parcel FE + Year-Month FE (most saturated) ---
m4 <- feols(
log_price ~ surge_x_elev + surge_x_dist | PIN + sale_year^sale_mm,
data    = panel_est,
cluster = ~sale_year
)
cat("=== MODEL SUMMARIES ===\n\n")
cat("Model 1 - Pooled OLS:\n")
print(summary(m1))
cat("\nModel 2 - Parcel FE:\n")
print(summary(m2))
cat("\nModel 3 - Parcel FE + Year FE (preferred):\n")
print(summary(m3))
cat("\nModel 4 - Parcel FE + Year-Month FE:\n")
print(summary(m4))
# Check types on both sides of the join
cat("panel sale_year type:", class(panel_spatial$sale_year), "\n")
cat("panel sale_mm type:", class(panel_spatial$sale_mm), "\n")
cat("tidal_final year type:", class(tidal_final$year), "\n")
cat("tidal_final month type:", class(tidal_final$month), "\n")
# Check a few values
cat("\nPanel sale years sample:", head(panel_spatial$sale_year), "\n")
cat("Tidal years sample:", head(tidal_final$year), "\n")
cat("Panel sale_mm sample:", head(panel_spatial$sale_mm), "\n")
cat("Tidal month sample:", head(tidal_final$month), "\n")
panel_spatial |>
count(sale_year) |>
print(n = 50)
# ============================================================
# 13. RESULTS TABLE - etable()
# ============================================================
etable(
m1, m2, m3, m4,
title      = "Flood Risk Capitalization in Tybee Island Housing Markets",
headers    = c("Pooled OLS", "Parcel FE", "Parcel + Year FE", "Parcel + Year-Month FE"),
coefstat   = "se",
signif.code = c("***" = 0.01, "**" = 0.05, "*" = 0.10),
digits     = 4,
fitstat    = ~ r2 + wr2 + n,
notes      = "Standard errors clustered at the year level. Dependent variable is log sale price. surge_x_elev = detrended monthly maximum water level x parcel elevation (m). surge_x_dist = detrended monthly maximum water level x distance to nearest NHD flowline (ft). Parcel fixed effects absorb all time-invariant parcel characteristics. Year fixed effects absorb common annual price shocks."
)
# ==========
# 14. SUMMARY STATS
# ==========
library(modelsummary)
library(kableExtra)
# ============================================================
# SUMMARY STATISTICS TABLE
# ============================================================
# Select and label variables for the table
panel_summary <- panel_est |>
select(
`Log Sale Price`           = log_price,
`Sale Price ($)`           = sale_price,
`Elevation (m)`            = elevation,
`Distance to Water (ft)`   = dist_water_ft,
`Surge Detrended (ft)`     = surge_detrended,
`Surge x Elevation`        = surge_x_elev,
`Surge x Distance`         = surge_x_dist,
`Year Built`               = year_built,
`Lot Size (acres)`         = acres
)
datasummary_skim(
panel_summary,
output = "latex",
title  = "Summary Statistics\\label{tab:summary}",
notes  = "Sample restricted to Tybee Island parcels with valid sale price,
elevation, distance to water, and surge observations, 2000--2023.
Surge Detrended is the residual from a linear regression of monthly
maximum water level on a time trend using NOAA Fort Pulaski gauge data.
Surge x Elevation and Surge x Distance are the interaction terms
entering the main specification."
)
